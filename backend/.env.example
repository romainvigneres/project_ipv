# Application
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database
DATABASE_URL=postgresql+asyncpg://ipv_user:ipv_password@db:5432/ipv_db

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://your-dmz-domain.example.com

# External SaaS API
SAAS_BASE_URL=https://api.your-saas.example.com
SAAS_API_KEY=your-saas-api-key
SAAS_TIMEOUT=30

# Email (SMTP)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@yourcompany.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@yourcompany.com

# Azure AD (optional, leave empty for local JWT auth)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
